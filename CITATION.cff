    given-names: Chandrahas
    orcid: "https://orcid.org/0009-0005-5410-7190"
url: "https://hpoexplorer.com"
repository-code: "https://github.com/mchandrahasreddy/hpoexplorer"
keywords:
  - Human Phenotype Ontology
  - HPO
  - deep phenotyping
  - clinical NLP
  - phenotype extraction
  - rare disease
  - genomic diagnosis
